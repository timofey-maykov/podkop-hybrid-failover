+/** Accepts Podkop proxy URIs plus Amnezia `vpn://…` (decoded on router by python3 + sing_box_config_facade). */
+function validateProxyUrlOrAmneziaVpn(value) {
+  if (!value || value.length === 0) {
+    return true;
+  }
+  if (typeof value === "string") {
+    const t = value.trim();
+    if (/^vpn:\/\//i.test(t)) {
+      return t.length >= 24
+        ? true
+        : _("Amnezia vpn:// link looks too short");
+    }
+    const validation = main.validateProxyUrl(value);
+    return validation.valid ? true : validation.message;
+  }
+  if (Array.isArray(value)) {
+    const shortVpn = value.some(
+      (v) =>
+        typeof v === "string" &&
+        /^vpn:\/\//i.test(v.trim()) &&
+        v.trim().length < 24,
+    );
+    if (shortVpn) {
+      return _("Amnezia vpn:// link looks too short");
+    }
+    const nonVpn = value.filter(
+      (v) => !(typeof v === "string" && /^vpn:\/\//i.test(v.trim())),
+    );
+    if (nonVpn.length === 0) {
+      return true;
+    }
+    const validation = main.validateProxyUrl(
+      nonVpn.length === 1 ? nonVpn[0] : nonVpn,
+    );
+    return validation.valid ? true : validation.message;
+  }
+  const validation = main.validateProxyUrl(value);
+  return validation.valid ? true : validation.message;
+}
