#!/bin/sh /etc/rc.common

START=97
STOP=10
USE_PROCD=1

CONF="podkop-telegram-bot"

start_service() {
	local enabled binary config_path log_path

	config_load "$CONF"
	config_get enabled main enabled "0"
	config_get binary main binary "/usr/bin/podkop-telegram-bot"
	config_get config_path main config_path "/etc/podkop-telegram-bot.json"
	config_get log_path main log_path "/var/log/podkop-telegram-bot.log"

	[ "$enabled" = "1" ] || return 0
	[ -x "$binary" ] || {
		logger -t podkop-telegram-bot "binary not executable: $binary"
		return 1
	}

	procd_open_instance
	procd_set_param command "$binary" -config "$config_path" -mode run
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file "$config_path"
	procd_set_param env PODKOP_BOT_LOG_PATH="$log_path"
	procd_close_instance
}

reload_service() {
	stop
	start
}
