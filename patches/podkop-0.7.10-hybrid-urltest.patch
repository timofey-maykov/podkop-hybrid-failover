 # Migrations and validation funcs
+migration_mark_changed=0
+
+_option_exists() {
+    local config="$1"
+    local section="$2"
+    local option="$3"
+    uci -q get "${config}.${section}.${option}" > /dev/null 2>&1
+}
+
+_mark_migration_change() {
+    migration_mark_changed=1
+}
+
+_migrate_section_v1() {
+    local section="$1"
+    local connection_type failover_vpn_enabled failover_proxy_links
+
+    config_get connection_type "$section" "connection_type"
+    config_get failover_vpn_enabled "$section" "failover_vpn_enabled"
+    config_get failover_proxy_links "$section" "failover_proxy_links"
+
+    # New bool option: keep explicit default in UCI for stable behavior across UI/CLI.
+    if ! _option_exists "podkop" "$section" "failover_vpn_enabled"; then
+        uci_set "podkop" "$section" "failover_vpn_enabled" 0
+        _mark_migration_change
+    fi
+
+    # If backup links are already configured on VPN section, enable failover automatically.
+    if [ "$connection_type" = "vpn" ] && [ -n "$failover_proxy_links" ] && [ "$failover_vpn_enabled" != "1" ]; then
+        uci_set "podkop" "$section" "failover_vpn_enabled" 1
+        _mark_migration_change
+    fi
+
+    # New urltest flag used in both proxy/urltest and vpn/failover flows.
+    if ! _option_exists "podkop" "$section" "urltest_interrupt_exist_connections"; then
+        uci_set "podkop" "$section" "urltest_interrupt_exist_connections" 0
+        _mark_migration_change
+    fi
+}
+
 migration() {
-    :
+    local schema_version target_schema
+    target_schema=1
+    schema_version="$(uci_get "podkop" "settings" "config_schema_version" 0)"
+    [ -z "$schema_version" ] && schema_version=0
+
+    if [ "$schema_version" -lt 1 ]; then
+        log "Run config migration to schema v1" "debug"
+        migration_mark_changed=0
+        config_foreach _migrate_section_v1 "section"
+        uci_set "podkop" "settings" "config_schema_version" "$target_schema"
+        migration_mark_changed=1
+
+        if [ "$migration_mark_changed" -eq 1 ]; then
+            uci commit "podkop"
+            config_load "$PODKOP_CONFIG"
+        fi
+    fi
 }
 
